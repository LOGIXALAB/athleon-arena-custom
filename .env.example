# Supabase — create a project at https://supabase.com, then copy these from
# Project Settings → API. Fill them into a real .env.local (gitignored).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# Public URL of this app (used to build manage links inside WhatsApp messages).
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# Brand/marketing site (the separate `athleon-arena` project). The app root and
# the "← Athleon Arena" back-links redirect here. Leave unset in dev to stay in-app.
NEXT_PUBLIC_MARKETING_URL=https://athleonarena.com

# Shared secret guarding the worker tick endpoint (POST /api/internal/tick).
CRON_SECRET=change-me-to-a-long-random-string
